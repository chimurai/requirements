{
  "name": "requirements",
  "version": "4.0.2",
  "license": "MIT",
  "author": "chimurai",
  "homepage": "https://github.com/chimurai/requirements",
  "bugs": {
    "url": "https://github.com/chimurai/requirements/issues"
  },
  "publishConfig": {
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chimurai/requirements.git"
  },
  "keywords": [
    "requirements",
    "software",
    "version",
    "checker"
  ],
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || >= 26.0.0"
  },
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "exports": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "bin": {
    "requirements": "bin/requirements.js"
  },
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig*.tsbuildinfo",
    "build": "tsc --build tsconfig.build.json",
    "lint": "oxfmt --check \"**/*.{js,ts,md}\" || echo '🔧  Run: \"npm run lint:fix\" to fix issues'",
    "lint:fix": "oxfmt --write \"**/*.{js,ts,md}\"",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepare": "husky",
    "prepack": "yarn clean && yarn test && yarn build",
    "gitignore:update": "curl -L https://www.toptal.com/developers/gitignore/api/node --silent > .temp && cat tools/dotgitignore | cat - .temp > .gitignore && rm .temp"
  },
  "lint-staged": {
    "**/*.{js,ts,md}": [
      "oxfmt --write"
    ]
  },
  "dependencies": {
    "binary-version": "^7.1.0",
    "chalk": "^5.0.0",
    "log-symbols": "7.0.1",
    "semver": "^7.5.2",
    "table": "^6.7.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "@types/yargs": "17.0.35",
    "@vitest/coverage-v8": "4.1.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "^0.57.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
